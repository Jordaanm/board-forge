{
  "name": "board-together",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "deploy:client": "npm run build --workspace=packages/client && npm run deploy:client:fast --workspace=packages/infra",
    "dev:client": "npm run dev --workspace=packages/client",
    "dev:server": "npm run dev --workspace=packages/server",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "concurrently": "^8.2.2"
  }
}
