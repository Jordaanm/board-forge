# Copy to .env.local (gitignored) and fill in real values.
# .env.local is sourced by Bun for local dev.

# Discord OAuth — used by POST /oauth/discord/exchange.
# CLIENT_ID is public (also exposed to the browser as VITE_DISCORD_CLIENT_ID).
# CLIENT_SECRET is server-only. Never expose to the client.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Comma-separated allowlist of redirect URIs accepted by /oauth/discord/exchange.
# Must match URIs registered in the Discord developer portal.
DISCORD_REDIRECT_URI_ALLOWLIST=http://localhost:5173/auth/discord/callback
